---
// DoraCountdown.astro — Animated hero visual showing DORA urgency → Phronesis relief
---
<div class="dora-widget" id="dora-widget">
  <!-- Left panel: the DORA panic state -->
  <div class="dora-panel dora-panic" id="dora-panic">
    <div class="dora-panel-header">
      <span class="panel-dot red"></span>
      <span class="panel-title mono">DORA Incident Window</span>
      <span class="badge badge-red">ACTIVE</span>
    </div>
    <div class="countdown-display">
      <div class="countdown-label">Time remaining to file initial report</div>
      <div class="countdown-timer" id="countdown-timer">3:47:22</div>
      <div class="countdown-sub">Article 5(4) — Initial notification deadline</div>
    </div>
    <div class="incident-log">
      <div class="log-row">
        <span class="log-time">14:03:18</span>
        <span class="log-msg log-red">⚠ Agent hallucination — FX routing decision</span>
      </div>
      <div class="log-row blink-row">
        <span class="log-time">14:03:21</span>
        <span class="log-msg log-amber">⏳ Manual reconstruction in progress...</span>
      </div>
    </div>
    <div class="dora-footer-note">Without Phronesis: Engineers digging through logs for 3+ days</div>
  </div>

  <!-- Right panel: the Phronesis safe state -->
  <div class="dora-panel dora-safe" id="dora-safe">
    <div class="dora-panel-header">
      <span class="panel-dot green"></span>
      <span class="panel-title mono">Phronesis Flight Recorder</span>
      <span class="badge badge-green">PROTECTED</span>
    </div>
    <div class="evidence-ready">
      <div class="evidence-check">✓</div>
      <div class="evidence-title">Evidence Pack Ready</div>
      <div class="evidence-time">Generated in <strong>3.2 seconds</strong></div>
    </div>
    <div class="evidence-details">
      <div class="evidence-row">
        <span class="evidence-icon">🎬</span>
        <span>Forensic Replay — 47 agent steps traced</span>
      </div>
      <div class="evidence-row">
        <span class="evidence-icon">📋</span>
        <span>DORA Initial Report — Structured & ready</span>
      </div>
      <div class="evidence-row">
        <span class="evidence-icon">🔒</span>
        <span>Ledger Hash — Cryptographically verified</span>
      </div>
    </div>
    <button class="btn btn-primary evidence-btn" onclick="void(0)">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Export DORA Evidence Pack
    </button>
  </div>

  <!-- Circuit background animation -->
  <div class="circuit-bg" aria-hidden="true">
    <svg class="circuit-svg" viewBox="0 0 600 300" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
      <!-- Circuit traces -->
      <path class="circuit-path" d="M0 80 H120 V40 H200 V80 H350 V120 H500 V80 H600" fill="none" stroke="rgba(0,212,255,0.12)" stroke-width="1.5"/>
      <path class="circuit-path-2" d="M0 160 H80 V200 H180 V160 H280 V220 H400 V160 H600" fill="none" stroke="rgba(59,130,246,0.1)" stroke-width="1.5"/>
      <path class="circuit-path-3" d="M100 0 V60 H160 V120" fill="none" stroke="rgba(0,212,255,0.08)" stroke-width="1"/>
      <path class="circuit-path-4" d="M420 300 V240 H480 V180" fill="none" stroke="rgba(59,130,246,0.08)" stroke-width="1"/>
      <!-- Data nodes -->
      <circle cx="120" cy="80" r="4" fill="rgba(0,212,255,0.3)"/>
      <circle cx="200" cy="40" r="3" fill="rgba(0,212,255,0.2)"/>
      <circle cx="350" cy="80" r="4" fill="rgba(59,130,246,0.3)"/>
      <circle cx="500" cy="80" r="3" fill="rgba(0,212,255,0.2)"/>
      <circle cx="180" cy="160" r="4" fill="rgba(59,130,246,0.3)"/>
      <circle cx="400" cy="220" r="3" fill="rgba(0,212,255,0.2)"/>
    </svg>
    <!-- Moving data packets -->
    <div class="data-packet packet-1"></div>
    <div class="data-packet packet-2"></div>
    <div class="data-packet packet-3"></div>
  </div>
</div>

<style>
.dora-widget {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
  position: relative;
  max-width: 780px;
  margin: 0 auto;
}

.circuit-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
  overflow: hidden;
  border-radius: var(--radius-xl);
  z-index: 0;
}
.circuit-svg {
  width: 100%;
  height: 100%;
}

/* Panels */
.dora-panel {
  position: relative;
  z-index: 1;
  border-radius: var(--radius-lg);
  padding: 1.25rem;
  border: 1px solid var(--color-border);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  overflow: hidden;
}

.dora-panic {
  background: rgba(10, 22, 40, 0.9);
  border-color: rgba(239,68,68,0.25);
}
.dora-safe {
  background: rgba(10, 22, 40, 0.9);
  border-color: rgba(16,185,129,0.3);
  box-shadow: 0 0 40px rgba(16,185,129,0.1);
}

/* Panel header */
.dora-panel-header {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 1rem;
  flex-wrap: wrap;
}
.panel-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}
.panel-dot.red   { background: var(--color-red);   animation: pulse-amber 1.5s ease-in-out infinite; }
.panel-dot.green { background: var(--color-green); }
.panel-title {
  font-size: 0.72rem;
  color: var(--color-text-muted);
  flex: 1;
}

/* Countdown */
.countdown-display {
  text-align: center;
  margin-bottom: 1rem;
  background: rgba(0,0,0,0.3);
  border-radius: var(--radius-lg);
  padding: 1rem 0.75rem;
  border: 1px solid rgba(245,158,11,0.15);
}
.countdown-label {
  font-size: 0.7rem;
  color: var(--color-text-dim);
  margin-bottom: 0.35rem;
  font-family: var(--font-mono);
}
.countdown-timer {
  font-family: var(--font-mono);
  font-size: 2.2rem;
  font-weight: 700;
  color: var(--color-amber);
  letter-spacing: 0.05em;
  animation: pulse-amber 2s ease-in-out infinite;
  line-height: 1;
  margin-bottom: 0.25rem;
}
.countdown-sub {
  font-size: 0.65rem;
  color: var(--color-red);
  font-family: var(--font-mono);
  opacity: 0.8;
}

/* Log */
.incident-log {
  background: rgba(0,0,0,0.4);
  border-radius: var(--radius-md);
  padding: 0.75rem;
  margin-bottom: 0.75rem;
  font-family: var(--font-mono);
  font-size: 0.68rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.log-row {
  display: flex;
  gap: 0.5rem;
  align-items: flex-start;
}
.log-time { color: var(--color-text-dim); flex-shrink: 0; }
.log-red   { color: var(--color-red); }
.log-amber { color: var(--color-amber); }
.log-muted { color: var(--color-text-muted); }
.blink-row { animation: blink 1.2s ease-in-out infinite; }

.dora-footer-note {
  font-size: 0.68rem;
  color: var(--color-red);
  text-align: center;
  font-style: italic;
  opacity: 0.8;
}

/* Evidence ready */
.evidence-ready {
  text-align: center;
  margin-bottom: 1rem;
}
.evidence-check {
  font-size: 2.5rem;
  color: var(--color-green);
  line-height: 1;
  margin-bottom: 0.35rem;
}
.evidence-title {
  font-family: var(--font-heading);
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 0.2rem;
}
.evidence-time {
  font-size: 0.78rem;
  color: var(--color-text-muted);
}
.evidence-time strong { color: var(--color-green); }

.evidence-details {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  margin-bottom: 1rem;
}
.evidence-row {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.78rem;
  color: var(--color-text-muted);
  background: rgba(16,185,129,0.05);
  padding: 0.4rem 0.6rem;
  border-radius: var(--radius-sm);
  border: 1px solid rgba(16,185,129,0.1);
}
.evidence-icon { font-size: 1rem; }
.evidence-btn {
  width: 100%;
  justify-content: center;
  font-size: 0.82rem;
  padding: 0.6rem 1rem;
}

/* Data packets */
.data-packet {
  position: absolute;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--color-cyan);
  box-shadow: 0 0 8px var(--color-cyan);
}
.packet-1 {
  top: 26%;
  animation: data-stream 3s linear infinite;
}
.packet-2 {
  top: 52%;
  animation: data-stream 4s linear 1.5s infinite;
  background: var(--color-blue);
  box-shadow: 0 0 8px var(--color-blue);
}
.packet-3 {
  top: 15%;
  animation: data-stream 5s linear 0.7s infinite;
  width: 4px;
  height: 4px;
  opacity: 0.7;
}

@media (max-width: 640px) {
  .dora-widget {
    grid-template-columns: 1fr;
  }
  .countdown-timer { font-size: 1.8rem; }
}
</style>

<script>
  // Countdown timer logic
  let totalSeconds = 3 * 3600 + 47 * 60 + 22;
  const timerEl = document.getElementById('countdown-timer');

  function updateTimer() {
    if (!timerEl || totalSeconds <= 0) return;
    totalSeconds--;
    const h = Math.floor(totalSeconds / 3600);
    const m = Math.floor((totalSeconds % 3600) / 60);
    const s = totalSeconds % 60;
    timerEl.textContent = `${h}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;

    // Color shifts as time runs low
    if (totalSeconds < 3600) {
      timerEl.style.color = 'var(--color-red)';
    }
  }

  setInterval(updateTimer, 1000);
</script>
