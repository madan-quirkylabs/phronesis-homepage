---
// HowItWorks.astro
import AnimatedTimeline from '../ui/AnimatedTimeline.astro';
---
<section class="section bg-surface-alt" id="how-it-works">
  <div class="container">
    <div class="section-header">
      <div class="section-label">⚙ How It Works</div>
      <h2>From chaos to clarity<br/>in three steps.</h2>
      <p>Three simple steps. Minimal effort on your side. We do the heavy lifting out of the box.</p>
    </div>

    <!-- Steps -->
    <div class="steps-layout">
      <div class="steps-list">
        <div class="step-item" id="step-1">
          <div class="step-header">
            <div class="step-number">01</div>
            <div class="step-connector" aria-hidden="true"></div>
          </div>
          <div class="step-content">
            <h3>Connect</h3>
            <p>Point your existing monitoring to Phronesis. No code changes to your AI agents. It's a completely out-of-the-box integration.</p>
          </div>
        </div>

        <div class="step-item" id="step-2">
          <div class="step-header">
            <div class="step-number">02</div>
            <div class="step-connector" aria-hidden="true"></div>
          </div>
          <div class="step-content">
            <h3>Monitor</h3>
            <p>Every agent decision is automatically captured, structured, and securely stored without any manual intervention. Your continuous compliance posture is visible at a glance.</p>
            <div class="monitor-status" style="margin-top: 1rem;">
              <div class="status-row">
                <span class="status-dot dot-green"></span>
                <span>14 Agent Workflows — Governed</span>
              </div>
              <div class="status-row">
                <span class="status-dot dot-green"></span>
                <span>0 Anomalous Incidents — Last 30 days</span>
              </div>
              <div class="status-row">
                <span class="status-dot dot-cyan"></span>
                <span>DORA & RBI Posture — Ready</span>
              </div>
            </div>
          </div>
        </div>

        <div class="step-item" id="step-3">
          <div class="step-header">
            <div class="step-number">03</div>
          </div>
          <div class="step-content">
            <h3>Respond</h3>
            <p>When asked for an audit trail, click once. The evidence is ready immediately, formatted perfectly for regulatory submission.</p>
            <div class="report-output">
              <div class="report-file">
                <span class="report-icon">📋</span>
                <div>
                  <div class="report-name">RBI_Cyber_Incident_Report_20250609.pdf</div>
                  <div class="report-meta mono">Generated in 3.2s · Hash: a8f2c1...</div>
                </div>
                <span class="badge badge-green">Ready</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Live visualization -->
      <div class="steps-visual">
        <div class="visual-label">
          <span class="section-label" style="margin: 0;">Live Trace Preview</span>
        </div>
        <AnimatedTimeline />
      </div>
    </div>
  </div>
</section>

<style>
.steps-layout {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 4rem;
  align-items: start;
}

.steps-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.step-item {
  display: grid;
  grid-template-columns: 48px 1fr;
  gap: 1.25rem;
  padding-bottom: 2.5rem;
}

.step-header {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-number {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: var(--color-surface-2);
  border: 1.5px solid var(--color-cyan);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-mono);
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--color-cyan);
  flex-shrink: 0;
}

.step-connector {
  flex: 1;
  width: 2px;
  background: linear-gradient(to bottom, var(--color-cyan), var(--color-border));
  margin-top: 8px;
  position: relative;
  overflow: hidden;
  min-height: 40px;
}
.step-connector::after {
  content: '';
  position: absolute;
  top: -6px;
  left: -2px;
  width: 6px;
  height: 12px;
  background: var(--color-cyan);
  border-radius: var(--radius-sm);
  box-shadow: 0 0 8px var(--color-cyan);
  animation: flow-down 2.5s linear infinite;
}

.step-content { padding-top: 0.5rem; }
.step-content h3 { font-size: 1.3rem; margin-bottom: 0.5rem; }
.step-content p  { font-size: 0.92rem; margin-bottom: 1rem; }

/* Monitor status */
.monitor-status {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  background: rgba(0,0,0,0.3);
  border-radius: var(--radius-md);
  padding: 0.75rem 1rem;
  border: 1px solid var(--color-border);
}
.status-row {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-size: 0.84rem;
  color: var(--color-text-muted);
}
.status-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.dot-green { background: var(--color-green); box-shadow: 0 0 6px var(--color-green); }
.dot-cyan  { background: var(--color-cyan);  box-shadow: 0 0 6px var(--color-cyan); animation: blink 2s ease-in-out infinite; }

/* Report output */
.report-output {
  background: rgba(0,0,0,0.3);
  border-radius: var(--radius-md);
  padding: 0.75rem;
  border: 1px solid rgba(16,185,129,0.2);
}
.report-file {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}
.report-icon { font-size: 1.5rem; }
.report-name { font-size: 0.82rem; color: var(--color-text); font-weight: 500; }
.report-meta { font-size: 0.68rem; color: var(--color-text-dim); margin-top: 0.15rem; }

/* Visual sticky panel */
.steps-visual {
  position: sticky;
  top: 100px;
}
.visual-label { margin-bottom: 1rem; }

@media (max-width: 1024px) {
  .steps-layout { grid-template-columns: 1fr; }
  .steps-visual { position: static; }
}
</style>
